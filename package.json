    "./skeleton": { "import": "./dist/skeleton.js" },
    "./statistic": { "import": "./dist/statistic.js" },
    "./step": { "import": "./dist/step.js" },
    "./tab": { "import": "./dist/tab.js" },
    "./table": { "import": "./dist/table.js" },
    "./tag": { "import": "./dist/tag.js" },
    "./title": { "import": "./dist/title.js" },
    "./tooltip": { "import": "./dist/tooltip.js" },
    "./tour": { "import": "./dist/tour.js" },
    "./tree": { "import": "./dist/tree.js" },
    "./clarity.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "version": "0.0.0",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "prepare": "husky"
  },
  "peerDependencies": {
    "element-plus": ">=2.7.6",
