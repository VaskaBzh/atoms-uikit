    "./collapse": { "import": "./dist/collapse.js" },
    "./date-picker": { "import": "./dist/date-picker.js" },
    "./divider": { "import": "./dist/divider.js" },
    "./empty": { "import": "./dist/empty.js" },
    "./form": { "import": "./dist/form.js" },
    "./icon": { "import": "./dist/icon.js" },
    "./input": { "import": "./dist/input.js" },
    "./menu": { "import": "./dist/menu.js" },
    "./modal": { "import": "./dist/modal.js" },
    "./pagination": { "import": "./dist/pagination.js" },
    "./popover": { "import": "./dist/popover.js" },
    "./progress": { "import": "./dist/progress.js" },
