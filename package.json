    "lodash": "^4.17.21",
    "path": "^0.12.7",
    "vite-plugin-dts": "^3.9.1",
    "vue-range-multi": "^0.2.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/node": "^20.14.11",
    "@vitejs/plugin-vue": "^5.1.4",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "sass": "^1.77.8",
    "typescript": "^5.2.2",
    "unplugin-auto-import": "^0.17.6",
    "unplugin-vue-components": "^0.27.2",
    "vite": "^5.3.1",
    "vitest": "^2.1.4",
